#!/bin/bash
# Install TPM plugins when tmux config changes
# tmux.conf.shared hash: {{ include "dot_dotfiles/tmux/tmux.conf.shared" | sha256sum }}

set -uo pipefail

TPM_DIR="$HOME/.dotfiles/tmux/plugins/tpm"
export TMUX_PLUGIN_MANAGER_PATH="$HOME/.dotfiles/tmux/plugins"

if [ ! -x "$TPM_DIR/bin/install_plugins" ]; then
    echo "TPM not found, skipping plugin install (run 'prefix + I' in tmux to install)"
    exit 0
fi

# TPM's install_plugins requires a running tmux server to read plugin
# definitions and TMUX_PLUGIN_MANAGER_PATH from the server environment.
if ! command -v tmux &>/dev/null || ! tmux list-sessions &>/dev/null 2>&1; then
    echo "No tmux server running, skipping plugin install (run 'prefix + I' inside tmux to install)"
    exit 0
fi

tmux set-environment -g TMUX_PLUGIN_MANAGER_PATH "$TMUX_PLUGIN_MANAGER_PATH"

if "$TPM_DIR/bin/install_plugins"; then
    echo "TPM plugins installed"
else
    echo "TPM plugin install failed (non-fatal). Run 'prefix + I' inside tmux to install manually."
fi
