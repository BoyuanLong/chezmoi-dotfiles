#!/bin/bash
# Install binary tools: fzf, zoxide, ripgrep
# Triggered on changes to this script.

set -euo pipefail

install_binary() {
    local cmd="$1"
    local pkg="$2"
    if command -v "$cmd" &>/dev/null; then
        echo "$cmd is already installed"
        return
    fi
    echo "Installing $pkg..."
    {{ if eq .chezmoi.os "darwin" -}}
    if command -v brew &>/dev/null; then
        brew install "$pkg"
    else
        echo "WARNING: brew not found, please install $pkg manually"
    fi
    {{ else if eq .chezmoi.os "linux" -}}
    if command -v apt-get &>/dev/null; then
        sudo apt-get install -y "$pkg"
    elif command -v dnf &>/dev/null; then
        sudo dnf install -y "$pkg"
    else
        echo "WARNING: no supported package manager found, please install $pkg manually"
    fi
    {{ end -}}
}

install_binary zsh zsh

# Change default shell to zsh if it isn't already
current_shell="$(basename "$SHELL")"
if [ "$current_shell" != "zsh" ] && command -v zsh &>/dev/null; then
    zsh_path="$(command -v zsh)"
    # Ensure zsh is in /etc/shells
    if ! grep -qF "$zsh_path" /etc/shells 2>/dev/null; then
        echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null
    fi
    echo "Changing default shell to zsh..."
    if chsh -s "$zsh_path" 2>/dev/null; then
        echo "Default shell changed to zsh"
    else
        echo "WARNING: could not change default shell (try: chsh -s $zsh_path)"
    fi
fi

install_binary tmux tmux
install_binary fzf fzf
install_binary zoxide zoxide
install_binary rg ripgrep
